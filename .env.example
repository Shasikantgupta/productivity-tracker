# ============================================
# Employee Productivity Analytics System
# Environment Configuration
# ============================================

# ---- Application Settings ----
APP_NAME=ProductivityTracker
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ---- Backend API ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- JWT Authentication ----
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- PostgreSQL Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=prodtracker
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=productivity_tracker
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ---- Screenshot Storage ----
SCREENSHOT_STORAGE=local
SCREENSHOT_PATH=./uploads/screenshots
SCREENSHOT_ENCRYPTION_KEY=your-32-byte-encryption-key-here
SCREENSHOT_MAX_SIZE_MB=5
SCREENSHOT_QUALITY=70
SCREENSHOT_INTERVAL_SECONDS=300

# ---- AI Analytics ----
AI_MODEL_PATH=./models
AI_ANALYSIS_INTERVAL_MINUTES=60
OPENAI_API_KEY=sk-your-openai-key-optional

# ---- Email / Notifications ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASSWORD=your-smtp-password
NOTIFICATION_FROM=noreply@yourcompany.com

# ---- Admin Dashboard ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Productivity Analytics

# ---- Docker ----
COMPOSE_PROJECT_NAME=productivity-tracker
