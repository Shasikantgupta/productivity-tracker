{
  "name": "productivity-agent",
  "version": "1.0.0",
  "description": "Employee Productivity Desktop Monitoring Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.company.productivity-agent",
    "productName": "Productivity Agent",
    "directories": { "output": "dist" },
    "win": { "target": ["nsis"], "icon": "assets/icon.ico" },
    "mac": { "target": ["dmg"], "icon": "assets/icon.icns" },
    "linux": { "target": ["AppImage"], "icon": "assets/icon.png" }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "active-win": "^8.1.0",
    "screenshot-desktop": "^1.15.0",
    "socket.io-client": "^4.7.4",
    "axios": "^1.6.5",
    "node-schedule": "^2.1.1",
    "systeminformation": "^5.21.22",
    "electron-log": "^5.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1"
  }
}
